{
    "name": "somardigital/silverstripe-forager-elasticsearch",
    "description": "Elasticsearch Search Provider for Silverstripe Forager",
    "type": "silverstripe-vendormodule",
    "license": "BSD-3-Clause",
    "authors": [
        {
            "name": "Somar Digital",
            "homepage": "https://www.somar.co.nz"
        }
    ],
    "keywords": [
        "Silverstripe",
        "Silverstripe CMS",
        "Search",
        "Elastic",
        "Elasticsearch",
        "Elastic Search"
    ],
    "require": {
        "php": "^8.3",
        "silverstripe/framework": "^6",
        "silverstripe/silverstripe-forager": "^2",
        "elasticsearch/elasticsearch": "^9"
    },
    "require-dev": {
        "phpunit/phpunit": "^11",
        "slevomat/coding-standard": "^8.8"
    },
    "autoload": {
        "psr-4": {
            "Somar\\ForagerElasticsearch\\": "src/",
            "Somar\\ForagerElasticsearch\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/installers": true,
            "silverstripe/vendor-plugin": true,
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "php-http/discovery": true,
            "silverstripe/recipe-plugin": true
        }
    }
}
